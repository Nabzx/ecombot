# AgentOps environment configuration.
# Copy to `.env` (`cp .env.example .env`) and adjust as needed. The `.env` file is
# git-ignored. Never commit real secrets. Every value below is a safe local default.

# --- PostgreSQL (consumed by the `db` service and to build DATABASE_URL) -------
POSTGRES_DB=agentops
POSTGRES_USER=agentops
POSTGRES_PASSWORD=agentops

# --- Backend ------------------------------------------------------------------
# Inside Docker Compose the host is the `db` service name; for non-Docker local
# development use `localhost` instead.
DATABASE_URL=postgresql+asyncpg://agentops:agentops@db:5432/agentops

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# Comma-separated list of allowed browser origins.
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Auth (used from a later stage) -------------------------------------------
# Development-only placeholder. MUST be replaced with a real secret in production;
# the app refuses to boot in production while this is unset/default.
JWT_SECRET=dev-only-insecure-change-me-0123456789ab
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Model layer / providers (S4) ---------------------------------------------
# The deterministic mock provider needs no network, no download and no secrets.
# It is the default everywhere and the only provider CI relies on.
LLM_DEFAULT_PROVIDER=mock
LLM_DEFAULT_MODEL=mock-deterministic-v1
# Comma-separated provider fallback order tried on retryable failures.
LLM_FALLBACK_ORDER=mock
LLM_FALLBACK_ENABLED=true

# Optional local Ollama provider (disabled by default; never required for tests/CI).
LLM_OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional hosted OpenAI-compatible provider (disabled by default; no key committed).
LLM_HOSTED_ENABLED=false
# HOSTED_PROVIDER_BASE_URL=https://api.openai.com/v1
HOSTED_PROVIDER_MODEL=gpt-4o-mini
# HOSTED_PROVIDER_API_KEY=

# Timeouts, retries and safety limits.
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_TOTAL_DEADLINE_SECONDS=90
LLM_MAX_RETRIES=2
LLM_DEFAULT_TEMPERATURE=0.0
LLM_MAX_INPUT_CHARS=24000
LLM_MAX_OUTPUT_TOKENS=1024

# Persistence / redaction. Redaction stays on; raw customer output is not stored.
LLM_PROMPT_PERSISTENCE_ENABLED=true
LLM_RAW_OUTPUT_PERSISTENCE_ENABLED=false
LLM_PII_REDACTION_ENABLED=true
LLM_COST_TABLE_VERSION=price-table-2026-07

# --- Telemetry (future stage) -------------------------------------------------
OTEL_ENABLED=false
# OTEL_EXPORTER_ENDPOINT=

# --- Frontend -----------------------------------------------------------------
# Base URL the browser uses to reach the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
